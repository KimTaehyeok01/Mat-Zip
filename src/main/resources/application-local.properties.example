# 이 파일을 복사해서 application-local.properties 로 저장하고 실제 값을 채우세요.
# application-local.properties 는 .gitignore 에 포함되어 있어 git에 올라가지 않습니다.

# PostgreSQL (Supabase)
DB_URL=jdbc:postgresql://aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require
DB_USERNAME=postgres.xxxxxxxxxxxxxxxxxxxxxxxx
DB_PASSWORD=your_db_password

# JWT (256bit 이상 랜덤 문자열 사용 권장)
# 생성 예: openssl rand -base64 64
JWT_SECRET=your-strong-random-jwt-secret-at-least-256-bits

# Kakao OAuth2
KAKAO_CLIENT_ID=your_kakao_client_id
KAKAO_CLIENT_SECRET=your_kakao_client_secret

# Naver OAuth2
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# Frontend URL
APP_FRONTEND_URL=http://localhost:3000